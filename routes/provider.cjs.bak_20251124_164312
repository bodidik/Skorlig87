/**
 * POST /api/provider/warn
 * body: { name:"AF", warn: 0.9 | 90 | 900 }
 *
 * - 0 < warn <= 1  → oran (daily * warn)
 * - 1 < warn <=100 → yüzde (daily * warn / 100)
 * - >100          → mutlak çağrı sayısı
 */
router.post("/warn", express.json(), async (req, res) => {
  try {
    const name = String(
      req.body?.name || ""
    ).toUpperCase();
    let warn = Number(req.body?.warn);

    if (!name || !Number.isFinite(warn)) {
      return res
        .status(400)
        .json({ ok: false, error: "REQUIRED" });
    }

    const m = await loadModel();
    if (!m.quotas[name]) {
      m.quotas[name] = { daily: 1000, used: 0, warn: 900 };
    }

    const q = m.quotas[name];
    const daily = Math.max(1, Number(q.daily || 0) || 1);

    if (warn > 0 && warn <= 1) {
      // oran
      q.warn = Math.round(daily * warn);
    } else if (warn > 1 && warn <= 100) {
      // yüzde
      q.warn = Math.round((daily * warn) / 100);
    } else {
      // mutlak sayı
      q.warn = Math.round(warn);
    }

    m.updatedAt = new Date().toISOString();
    await writeJson(FILE_PATH, m);
    res.json({ ok: true, quota: q });
  } catch (e) {
    res.status(500).json({
      ok: false,
      error: "WARN_SET_FAILED",
      detail: String(e && (e.message || e)),
    });
  }
});


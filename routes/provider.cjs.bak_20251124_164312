  } catch (e) {
    res.status(500).json({
      ok: false,
      error: "TEAM_PRIMARY_GET_FAILED",
      detail: String(e && (e.message || e)),
    });
  }
});

/**
 * POST /api/provider/team-primary
 * body: { team:"Galatasaray", provider:"TSDB" }
 */
router.post("/team-primary", express.json(), async (req, res) => {
  try {
    const teamRaw = String(req.body?.team || "");
    const providerRaw = String(
      req.body?.provider || ""
    ).toUpperCase();

    const team = teamKey(teamRaw);
    if (!team || !providerRaw) {
      return res
        .status(400)
        .json({ ok: false, error: "REQUIRED" });
    }

    const m = await loadModel();
    const all = providerNames(m);
    if (!all.includes(providerRaw)) {
      return res.status(400).json({
        ok: false,
        error: "PROVIDER_INVALID",
      });
    }

    m.teamPref = m.teamPref || {};
    m.teamPref[team] = providerRaw;

    // eski alanlarla uyum için
    m.primary = m.primary || {};
    m.primary[team] = providerRaw;
    m.teamPrimary = m.teamPrimary || {};
    m.teamPrimary[team] = providerRaw;

    m.updatedAt = new Date().toISOString();
    await writeJson(FILE_PATH, m);

    res.json({ ok: true, team, provider: providerRaw });
  } catch (e) {
    res.status(500).json({
      ok: false,
      error: "TEAM_PRIMARY_SET_FAILED",
      detail: String(e && (e.message || e)),
    });
  }
});


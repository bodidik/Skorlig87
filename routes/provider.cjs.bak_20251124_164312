/**
 * GET /api/provider/diag
 * Tüm modelin ham çıktısı (admin panel için).
 */
router.get("/diag", async (req, res) => {
  const m = await loadModel();
  res.json({ ok: true, model: m });
});

/**
 * POST /api/provider/mark
 * Örnek:
 *   POST /api/provider/mark?name=AF&ok=1&ms=120
 * veya
 *   body: { name:"AF", ok:1, ms:120 }
 */
router.post("/mark", express.json(), async (req, res) => {
  try {
    const name = String(
      req.query.name || req.body?.name || ""
    ).toUpperCase();
    const okFlag =
      String(req.query.ok ?? req.body?.ok ?? "1") === "1";
    const ms = Number(req.query.ms ?? req.body?.ms ?? 0) || 0;

    if (!name) {
      return res
        .status(400)
        .json({ ok: false, error: "NAME_REQUIRED" });
    }

    const m = await loadModel();
    if (!m.providers[name]) {
      // bilinmeyen provider da olsa model’e ekleyelim
      m.providers[name] = {
        ok: 0,
        fail: 0,
        lastMs: 0,
        lastAt: null,
        weight: 1.0,
      };
    }
    if (!m.quotas[name]) {
      m.quotas[name] = { daily: 1000, used: 0, warn: 900 };
    }

    const p = m.providers[name];
    const q = m.quotas[name];

    if (okFlag) p.ok++;
    else p.fail++;

    p.lastMs = ms;
    p.lastAt = new Date().toISOString();
    q.used = Math.max(0, Number(q.used || 0) + 1);

    m.updatedAt = new Date().toISOString();
    await writeJson(FILE_PATH, m);

    res.json({ ok: true, provider: name, stats: p, quota: q });
  } catch (e) {
    res.status(500).json({
      ok: false,
      error: "MARK_FAILED",
      detail: String(e && (e.message || e)),
    });
  }
});

/**
 * POST /api/provider/reset
 * - /reset?name=AF → sadece AF’yi sıfırlar
 * - /reset        → tüm modeli sıfırlar (boş + defaults)
 */
router.post("/reset", async (req, res) => {
  try {
    const name = String(req.query.name || "").toUpperCase();
    let m = await loadModel();

    if (name) {
      if (!m.providers[name] && !m.quotas[name]) {
        return res
          .status(400)
          .json({ ok: false, error: "NAME_INVALID" });
      }
      const base = baseModel();
      const baseProv = base.providers[name] || {
        ok: 0,
        fail: 0,
        lastMs: 0,
        lastAt: null,
        weight: 1.0,
      };
      const baseQuota = base.quotas[name] || {
        daily: 1000,
        used: 0,
        warn: 900,
      };

      m.providers[name] = { ...baseProv };
      m.quotas[name] = { ...baseQuota };
    } else {
      // komple reset: eski teamPref ve settings’i korumak isteyebiliriz
      const prev = m;
      const fresh = baseModel();
      fresh.teamPref = prev.teamPref || {};
      fresh.settings = prev.settings || fresh.settings;
      m = fresh;
    }

    m.updatedAt = new Date().toISOString();
    await writeJson(FILE_PATH, m);
    res.json({ ok: true, model: m });
  } catch (e) {
    res.status(500).json({
      ok: false,
      error: "RESET_FAILED",
      detail: String(e && (e.message || e)),
    });
  }
});

/**
 * GET /api/provider/next?team=Galatasaray
 *
 * Seçim mantığı:
 * 1) teamPref[TEAM] varsa ve kotası %90 altında ise → onu döner (via:"primary")
 * 2) aksi halde mevcut tüm provider’lar için score hesaplar,
 *    en yüksek skorlu olanı döner (via:"scored")
 */
router.get("/next", async (req, res) => {
  try {
    const teamRaw = String(req.query.team || "");
    const team = teamKey(teamRaw);

    const m = await loadModel();
    const all = providerNames(m);
    if (!all.length) {
      return res.status(500).json({
        ok: false,
        error: "NO_PROVIDERS",
      });
    }

    const Q90 = 0.9;

    // 1) Takım için atanmış primary (teamPref) varsa
    if (team && m.teamPref && m.teamPref[team]) {
      const prim = String(m.teamPref[team]).toUpperCase();
      if (m.quotas[prim]) {
        const ratio = quotaRatio(m.quotas[prim]);
        if (ratio < Q90) {
          return res.json({
            ok: true,
            provider: prim,
            via: "primary",
            team,
          });
        }
      }
    }

    // 2) Skorlu seçim
    const scored = all.map((name) => ({
      name,
      score: scoreProvider(m, name),
    }));

    scored.sort((a, b) => b.score - a.score);
    const chosen = scored[0]?.name || all[0];

    res.json({
      ok: true,
      provider: chosen,
      via: "scored",
      team,
      ranking: scored,
    });
  } catch (e) {
    res.status(500).json({
      ok: false,
      error: "NEXT_FAILED",
      detail: String(e && (e.message || e)),
    });
  }
});


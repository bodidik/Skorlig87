"use strict";

const express = require("express");
const router = express.Router();
const fs = require("fs");
const fsp = fs.promises;
const path = require("path");

const DATA_DIR = path.join(__dirname, "..", "data");
const FILE_PATH = path.join(DATA_DIR, "providers.json");

// ----------------- JSON HELPERS -----------------
async function readJson(file, fb) {
  try {
    const txt = await fsp.readFile(file, "utf8");
    return JSON.parse(txt);
  } catch {
    return fb;
  }
}

async function writeJson(file, data) {
  await fsp.mkdir(path.dirname(file), { recursive: true });
  await fsp.writeFile(file, JSON.stringify(data, null, 2), "utf8");
}

// ----------------- MODEL -----------------

function baseModel() {
  return {
    providers: {
      // AF = api-football, TSDB = TheSportsDB, FDO = Football-Data.org
      AF:   { ok: 0, fail: 0, lastMs: 0, lastAt: null, weight: 1.0 },
      TSDB: { ok: 0, fail: 0, lastMs: 0, lastAt: null, weight: 1.0 },
      FDO:  { ok: 0, fail: 0, lastMs: 0, lastAt: null, weight: 1.0 },
    },
    quotas: {
      AF:   { daily: 100,  used: 0, warn: 90  },   // warn: 90 çağrıda uyar
      TSDB: { daily: 1000, used: 0, warn: 900 },
      FDO:  { daily: 1000, used: 0, warn: 900 },
    },
    /**
     * takım bazlı ana sağlayıcı ataması:
     * teamPref["GALATASARAY"] = "TSDB"
     *
     * live2.cjs şu alanı kullanıyor.
     */
    teamPref: {},
    /**
     * Eski dosyalarla uyum için bırakılan alanlar;
     * yeni kod teamPref üzerinden çalışıyor.
     */
    primary: {},      // eski provider.cjs
    teamPrimary: {},  // eski provider2.cjs

    settings: {
      autoPrimary: true, // ilerde otomatik öğrenme kapat/aç için
    },

    updatedAt: new Date().toISOString(),
  };
}

/**
 * Verilen modeli baseModel ile birleştir, eksikleri doldur.
 * Eski dosyalardaki primary / teamPrimary → teamPref’e aynalanır.
 */
function ensureStruct(input) {
  const base = baseModel();
  const m = input && typeof input === "object" ? input : {};

  // providers
  m.providers = m.providers && typeof m.providers === "object"
    ? m.providers
    : {};
  for (const [name, defVal] of Object.entries(base.providers)) {
    if (!m.providers[name]) {
      m.providers[name] = { ...defVal };
    } else {
      const p = m.providers[name];
      p.ok = Number(p.ok || 0);
      p.fail = Number(p.fail || 0);
      p.lastMs = Number(p.lastMs || 0);
      p.lastAt = p.lastAt || null;
      p.weight = Number.isFinite(p.weight) ? p.weight : 1.0;
    }
  }

  // quotas
  m.quotas = m.quotas && typeof m.quotas === "object"
    ? m.quotas
    : {};
  for (const [name, defVal] of Object.entries(base.quotas)) {
    if (!m.quotas[name]) {
      m.quotas[name] = { ...defVal };
    } else {
      const q = m.quotas[name];
      q.daily = Number(q.daily || defVal.daily);
      q.used = Number(q.used || 0);
      q.warn = Number.isFinite(q.warn)
        ? Number(q.warn)
        : Number(defVal.warn);
    }
  }

  // teamPref + eski alanlardan merge
  m.teamPref = m.teamPref && typeof m.teamPref === "object"
    ? m.teamPref
    : {};

  m.primary = m.primary && typeof m.primary === "object"
    ? m.primary
    : {};
  m.teamPrimary = m.teamPrimary && typeof m.teamPrimary === "object"
    ? m.teamPrimary
    : {};

  // eski primary alanlarını teamPref içine kopyala (varsa)
  for (const [team, prov] of Object.entries(m.primary)) {
    const k = String(team || "").toUpperCase().trim();
    if (!k) continue;
    if (!m.teamPref[k] && typeof prov === "string") {
      m.teamPref[k] = prov.toUpperCase();
    }
  }
  for (const [team, prov] of Object.entries(m.teamPrimary)) {
    const k = String(team || "").toUpperCase().trim();
    if (!k) continue;
    if (!m.teamPref[k] && typeof prov === "string") {
      m.teamPref[k] = prov.toUpperCase();
    }
  }

  // settings
  m.settings = m.settings && typeof m.settings === "object"
    ? m.settings
    : {};
  m.settings.autoPrimary =
    typeof m.settings.autoPrimary === "boolean"
      ? m.settings.autoPrimary
      : true;

  m.updatedAt = new Date().toISOString();
  return m;
}

async function loadModel() {
  const raw = await readJson(FILE_PATH, null);
  const m = ensureStruct(raw || {});
  await writeJson(FILE_PATH, m);
  return m;
}

function providerNames(m) {
  return Object.keys(m.providers || {});
}

function teamKey(name) {
  return String(name || "").trim().toUpperCase();
}

function quotaRatio(q) {
  const daily = Math.max(1, Number(q.daily || 0) || 1);
  const used = Number(q.used || 0);
  return used / daily;
}

// ----------------- SCORE / SEÇİM ALGORİTMASI -----------------

/**
 * Bir sağlayıcı için skor hesapla:
 * - kota %90 altındaysa +2 puan
 * - successRate (ok / (ok+fail))
 * - speed: 1 / ms (5000 ms’e clamp)
 * - weight: manuel ağırlık (0.25x)
 */
function scoreProvider(m, name) {
  const p = (m.providers && m.providers[name]) || {};
  const q = (m.quotas && m.quotas[name]) || { daily: 1000, used: 0 };

  const ratio = quotaRatio(q);
  const quotaOK = ratio < 0.9 ? 1 : 0;
  const totalCalls = (p.ok || 0) + (p.fail || 0);
  const success = totalCalls > 0 ? p.ok / totalCalls : 0;
  const ms = Number(p.lastMs || 0);
  const speed = ms > 0 ? 1 / Math.min(ms, 5000) : 0;
  const weight = Number.isFinite(p.weight) ? p.weight : 1.0;

  return quotaOK * 2 + success + speed + 0.25 * weight;
}

